# Cloudflare API token used by the Cloudflare provider to manage the bucket.
# Account permission: Workers R2 Storage — Write
# Resource scope: only the Cloudflare account containing the state bucket
CLOUDFLARE_API_TOKEN=op://VAULT/ITEM/cloudflare_api_token

# Cloudflare account ID. Not a secret.
TF_VAR_cloudflare_account_id=op://VAULT/ITEM/cloudflare_account_id

# OpenTofu encryption
TF_VAR_state_encryption_passphrase=op://VAULT/ITEM/opentofu_state_passphrase

# S3 credentials generated from a separate R2 API token.
# Permission: Object Read & Write
# Bucket scope: only "arkham-build-opentofu-state"
AWS_ACCESS_KEY_ID=op://VAULT/ITEM/r2_access_key_id
AWS_SECRET_ACCESS_KEY=op://VAULT/ITEM/r2_secret_access_key
