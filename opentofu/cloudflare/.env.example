# Dedicated Cloudflare API token for infrastructure managed by this stack.
# Scope it to the arkham.build account and zone. Add only permissions required
# by declared resources; do not use the Global API Key.
CLOUDFLARE_API_TOKEN=op://VAULT/ITEM/cloudflare_infrastructure_api_token

# Cloudflare identifiers. Not secrets.
TF_VAR_cloudflare_account_id=op://VAULT/ITEM/cloudflare_account_id
TF_VAR_cloudflare_zone_id=op://VAULT/ITEM/cloudflare_zone_id

# Verified destination used by arkham.build forwarding rules. The destination
# address itself remains outside source control.
TF_VAR_email_routing_destination_address=op://VAULT/ITEM/email_routing_destination_address

# OpenTofu encryption.
TF_VAR_state_encryption_passphrase=op://VAULT/ITEM/opentofu_state_passphrase

# S3 credentials for the OpenTofu state backend.
# Permission: Object Read & Write
# Bucket scope: only "arkham-build-opentofu-state"
AWS_ACCESS_KEY_ID=op://VAULT/ITEM/r2_access_key_id
AWS_SECRET_ACCESS_KEY=op://VAULT/ITEM/r2_secret_access_key
